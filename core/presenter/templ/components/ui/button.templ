// core/presenter/templ/components/ui/button.templ
package ui

func buttonClasses(variant string) string {
    base := "inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 h-9 px-4 py-2"
    switch variant {
    case "secondary":
        return base + " border border-border bg-card text-foreground hover:bg-accent"
    case "ghost":
        return base + " hover:bg-accent hover:text-accent-foreground"
    case "destructive":
        return base + " bg-destructive text-destructive-foreground hover:bg-destructive/90"
    case "link":
        return "text-sm font-medium text-foreground underline-offset-4 hover:underline"
    default: // primary
        return base + " bg-primary text-primary-foreground hover:bg-primary/90"
    }
}

templ Button(variant, btnType string) {
    <button type={ btnType } class={ buttonClasses(variant) }>
        { children... }
    </button>
}

templ LinkButton(href, variant string) {
    <a href={ templ.SafeURL(href) } class={ buttonClasses(variant) }>
        { children... }
    </a>
}
